# DeepSeek API 配置（必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Redis 配置（用于速率限制和缓存）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=5s

# 应用配置
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# API 速率限制（每分钟请求数）
RATE_LIMIT=30
API_TIMEOUT=60

# 模型配置（可选择 Pro 或 Flash）
DEFAULT_MODEL=deepseek-v4-pro
FALLBACK_MODEL=deepseek-v4-flash

# JVM 内存配置
JAVA_OPTS="-Xms512m -Xmx1024m -XX:+UseG1GC"